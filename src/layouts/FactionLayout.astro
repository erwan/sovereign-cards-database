---
import '../styles/faction-layout.css';
import { getBaseUrl } from '../lib/baseUrl';
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const home = getBaseUrl();
---

<Layout title={title}>
  <main class="faction-main">
    <nav class="faction-nav">
      <a href={home}>← Home</a>
    </nav>
    <slot />
  </main>
</Layout>
