<!--
  Shared view toggle component for switching between list and gallery views
  Eliminates duplication between faction pages and all cards page
-->
---
interface Props {
  initialView?: 'list' | 'gallery';
}

const { initialView = 'gallery' } = Astro.props;
---

<div class="deck-view-toolbar" role="group" aria-label="Display mode">
  <div class="deck-view-switch" role="presentation">
    <input
      type="radio"
      class="deck-view-input"
      name="deck-view-mode"
      id="deck-view-list"
      value="list"
    />
    <label class="deck-view-option" for="deck-view-list">List</label>
    <input
      type="radio"
      class="deck-view-input"
      name="deck-view-mode"
      id="deck-view-gallery"
      value="gallery"
    />
    <label class="deck-view-option" for="deck-view-gallery">Cards</label>
  </div>
</div>

<script is:inline>
  (function () {
    var listRadio = document.getElementById("deck-view-list");
    var galleryRadio = document.getElementById("deck-view-gallery");
    if (!listRadio || !galleryRadio) return;

    function apply(view) {
      listRadio.checked = view === "list";
      galleryRadio.checked = view === "gallery";
      try {
        localStorage.setItem("sovereign-deck-display", view);
      } catch (e) {}
    }

    // Try to load saved preference
    try {
      var saved = localStorage.getItem("sovereign-deck-display");
      if (saved === "gallery" || saved === "list") {
        apply(saved);
      } else {
        apply(initialView);
      }
    } catch (e) {
      apply(initialView);
    }

    listRadio.addEventListener("change", function () {
      if (listRadio.checked) apply("list");
    });
    galleryRadio.addEventListener("change", function () {
      if (galleryRadio.checked) apply("gallery");
    });
  })();
</script>