---
import "../../styles/faction-detail.css";
import CardLightbox from "../../components/CardLightbox.astro";
import CardListItem from "../../components/CardListItem.astro";
import DeckHeader from "../../components/DeckHeader.astro";
import FactionLayout from "../../layouts/FactionLayout.astro";
import { getBaseUrl } from "../../lib/baseUrl";
import {
  DISPLAY_TYPE_ORDER,
  loadDecks,
  typeSectionHeading,
  type Deck,
} from "../../lib/decks";

export function getStaticPaths() {
  return loadDecks().map((deck) => ({
    params: { slug: deck.slug },
    props: { deck },
  }));
}

interface Props {
  deck: Deck;
}

const { deck } = Astro.props;
const typeStats = DISPLAY_TYPE_ORDER.map((type) => ({
  type,
  count: deck.cards.filter((c) => c.type === type).length,
})).filter((row) => row.count > 0);
const base = getBaseUrl();
const assetPrefix = `${base}cards/${deck.slug}/`;
const coverSrc = `${assetPrefix}cover.png`;
---

<FactionLayout title={`${deck.displayName} — Sovereign Cards`}>
  <div class="faction-detail">
    <DeckHeader deck={deck} coverSrc={coverSrc} typeStats={typeStats} />
    {
      DISPLAY_TYPE_ORDER.map((type) => {
        const sectionCards = deck.cards.filter((c) => c.type === type);
        if (sectionCards.length === 0) return null;
        return (
          <section class="card-type-section" aria-labelledby={`type-${type}`}>
            <h2 class="card-type-heading" id={`type-${type}`}>
              {typeSectionHeading(type)}
            </h2>
            <ul class="card-list">
              {sectionCards.map((card) => (
                <CardListItem card={card} assetPrefix={assetPrefix} />
              ))}
            </ul>
          </section>
        );
      })
    }
    <CardLightbox />
  </div>
</FactionLayout>
