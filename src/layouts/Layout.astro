---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
      defer></script>
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <p>
        This is a non-official, fan-made website. All rights to Sovereign: Fall
        of Wormwood belong to <a
          href="https://www.fallofwormwood.com/"
          target="_blank"
          rel="noopener noreferrer">Ixion Gameworks</a
        >.
      </p>
    </footer>
  </body>
</html>
