---
// Theme toggle component using Alpine.js
const themeScript = `
  document.addEventListener('alpine:init', () => {
    Alpine.data('themeToggle', () => ({
      theme: () => {
        if (typeof window !== 'undefined') {
          return localStorage.getItem('theme') || 
                 (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        }
        return 'dark';
      },
      
      init() {
        this.applyTheme();
        
        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
          if (!localStorage.getItem('theme')) {
            this.theme = e.matches ? 'light' : 'dark';
            this.applyTheme();
          }
        });
      },
      
      toggle() {
        this.theme = this.theme === 'dark' ? 'light' : 'dark';
        this.applyTheme();
      },
      
      applyTheme() {
        const html = document.documentElement;
        
        if (this.theme === 'light') {
          html.setAttribute('data-theme', 'light');
        } else {
          html.removeAttribute('data-theme');
        }
        
        localStorage.setItem('theme', this.theme);
      },
      
      get iconPath() {
        // Sun icon for dark mode (to switch to light)
        // Moon icon for light mode (to switch to dark)
        if (this.theme === 'dark') {
          return 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M12 4.5a7.5 7.5 0 100 15 7.5 7.5 0 000-15z';
        } else {
          return 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z';
        }
      }
    }));
  });
`;
---

<div
  x-data="themeToggle"
  x-init="applyTheme()"
  class="site-theme-toggle"
  :title="theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'"
  @click="toggle()"
>
  <svg 
    class="site-theme-icon" 
    viewBox="0 0 24 24" 
    xmlns="http://www.w3.org/2000/svg" 
    aria-hidden="true"
  >
    <path
      fill="currentColor"
      stroke="currentColor"
      stroke-width="2"
      fill-rule="evenodd"
      clip-rule="evenodd"
      :d="iconPath"
    />
  </svg>
</div>

<script is:inline>
  {themeScript}
</script>

<style>
  .site-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    cursor: pointer;
    border-radius: 4px;
  }

  .site-theme-toggle:hover {
    color: var(--accent-hover);
    background-color: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .site-theme-icon {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
  }
</style>
