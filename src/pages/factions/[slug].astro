---
import "../../styles/faction-detail.css";
import CardLightbox from "../../components/CardLightbox.astro";
import CardListItem from "../../components/CardListItem.astro";
import DeckCostHistograms from "../../components/DeckCostHistograms.astro";
import DeckHeader from "../../components/DeckHeader.astro";
import FactionLayout from "../../layouts/FactionLayout.astro";
import { getBaseUrl } from "../../lib/baseUrl";
import {
  type CardEntry,
  compareCardsByCostThenName,
  DISPLAY_TYPE_ORDER,
  loadDecks,
  typeSectionHeading,
  type Deck,
} from "../../lib/decks-content";

export async function getStaticPaths() {
  const decks = await loadDecks();
  return decks.map((deck) => ({
    params: { slug: deck.slug },
    props: { deck },
  }));
}

interface Props {
  deck: Deck;
}

const { deck } = Astro.props;
// typeStats is unused, removing it.
const base = getBaseUrl();
const assetPrefix = `${base}cards/${deck.slug}/`;
const coverSrc = `${assetPrefix}leader.jpg`;
---

<FactionLayout title={`${deck.displayName} — Sovereign Cards`}>
  <div
    slot="header-actions"
    class="deck-view-toolbar"
    role="group"
    aria-label="Display mode"
  >
    <div class="deck-view-switch" role="presentation">
      <input
        type="radio"
        class="deck-view-input"
        name="deck-view-mode"
        id="deck-view-list"
        value="list"
      />
      <label class="deck-view-option" for="deck-view-list">List</label>
      <input
        type="radio"
        class="deck-view-input"
        name="deck-view-mode"
        id="deck-view-gallery"
        value="gallery"
      />
      <label class="deck-view-option" for="deck-view-gallery">Cards</label>
    </div>
  </div>
  <div class="faction-detail" data-deck-view="gallery">
    <script is:inline>
      (function () {
        var root =
          document.currentScript && document.currentScript.parentElement;
        if (!root || !root.classList.contains("faction-detail")) return;
        var v = "gallery";
        try {
          var s = localStorage.getItem("sovereign-deck-display");
          if (s === "gallery" || s === "list") v = s;
        } catch (e) {}
        root.setAttribute("data-deck-view", v);
      })();
    </script>
    <DeckHeader deck={deck} coverSrc={coverSrc} />
    <DeckCostHistograms deck={deck} />
    {
      DISPLAY_TYPE_ORDER.map((type) => {
        const sectionCards = deck.cards
          .filter((c: CardEntry) => c.type === type)
          .sort(compareCardsByCostThenName);
        if (sectionCards.length === 0) return null;
        return (
          <section class="card-type-section" aria-labelledby={`type-${type}`}>
            <h2 class="card-type-heading" id={`type-${type}`}>
              {typeSectionHeading(type)}
            </h2>
            <ul class="card-list">
              {sectionCards.map((card: CardEntry) => (
                <CardListItem card={card} assetPrefix={assetPrefix} />
              ))}
            </ul>
          </section>
        );
      })
    }
    <CardLightbox />
    <script is:inline>
      (function () {
        var root = document.querySelector(".faction-detail");
        var listRadio = document.getElementById("deck-view-list");
        var galleryRadio = document.getElementById("deck-view-gallery");
        if (!root || !listRadio || !galleryRadio) return;

        function syncCardItemA11y(view) {
          root
            .querySelectorAll(".card-item[data-full-src]")
            .forEach(function (el) {
              var thumb = el.querySelector(".card-thumb");
              if (view === "list") {
                var name = el.getAttribute("data-card-name") || "";
                var cost = el.getAttribute("data-card-cost") || "";
                el.setAttribute("role", "button");
                el.setAttribute("tabindex", "0");
                el.setAttribute(
                  "aria-label",
                  "View full card: " + name + ", cost " + cost,
                );
                if (thumb) thumb.alt = "";
              } else {
                el.removeAttribute("role");
                el.removeAttribute("tabindex");
                el.removeAttribute("aria-label");
                if (thumb) thumb.alt = el.getAttribute("data-card-name") || "";
              }
            });
        }

        function apply(view) {
          root.setAttribute("data-deck-view", view);
          listRadio.checked = view === "list";
          galleryRadio.checked = view === "gallery";
          syncCardItemA11y(view);
          try {
            localStorage.setItem("sovereign-deck-display", view);
          } catch (e) {}
        }

        var current = root.getAttribute("data-deck-view") || "gallery";
        apply(current === "gallery" ? "gallery" : "list");

        listRadio.addEventListener("change", function () {
          if (listRadio.checked) apply("list");
        });
        galleryRadio.addEventListener("change", function () {
          if (galleryRadio.checked) apply("gallery");
        });
      })();
    </script>
  </div>
</FactionLayout>
