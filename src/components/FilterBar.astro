---
import "../styles/filter-bar.css";

interface Faction {
  slug: string;
  displayName: string;
}

interface CardData {
  cost?: string;
  type?: string;
  type_secondary?: string[];
}

interface Props {
  searchPlaceholder?: string;
  showFactionSelector?: boolean;
  factions?: Faction[];
  validSecondaryTypesByType?: Record<string, string[]>;
  allCards?: CardData[];
  initialState?: {
    search?: string;
    costs?: string[];
    type?: string;
    secondaryType?: string;
    faction?: string;
  };
}

const {
  searchPlaceholder = "Search cards...",
  showFactionSelector = true,
  factions = [],
  validSecondaryTypesByType,
  allCards = [],
  initialState = {},
} = Astro.props;
---

<div
  class="filter-bar"
  x-data="filterBarComponent(JSON.parse($el.dataset.initialState))"
  data-initial-state={JSON.stringify({
    ...initialState,
    showFactionSelector,
    factions,
    validSecondaryTypesByType,
    allCards,
  })}
>
  <div class="filter-group filter-group--search">
    <label for="search" class="filter-label">Search</label>
    <div class="filter-search-wrap">
      <input
        type="text"
        id="search"
        x-model="filters.search"
        placeholder={searchPlaceholder}
        class="filter-input filter-input--search"
        @input.debounce.300ms="emitFiltersChanged()"
        autocomplete="off"
      />
      <button
        type="button"
        class="filter-search-clear"
        x-show="filters.search.length > 0"
        x-cloak
        @click="clearSearch()"
        aria-label="Clear search"
      >
        <span aria-hidden="true">×</span>
      </button>
    </div>
  </div>

  <div class="filter-group filter-group--cost">
    <span class="filter-label" id="filter-cost-heading">Cost</span>
    <div
      class="filter-cost-dropdown"
      @click.outside="costDropdownOpen = false"
      @keydown.escape.window="costDropdownOpen = false"
    >
      <button
        type="button"
        class="filter-cost-trigger"
        aria-haspopup="true"
        :aria-expanded="costDropdownOpen"
        :aria-label="'Filter by cost, current: ' + costTriggerLabel()"
        @click="costDropdownOpen = !costDropdownOpen"
      >
        <span class="filter-cost-trigger-text" x-text="costTriggerLabel()"
        ></span>
        <span class="filter-cost-trigger-chevron" aria-hidden="true"></span>
      </button>
      <div
        class="filter-cost-panel"
        x-show="costDropdownOpen"
        x-cloak
        role="group"
        aria-label="Cost values"
      >
        <template x-for="cv in getAvailableCosts()" :key="cv">
          <div class="filter-cost-option">
            <label class="filter-cost-option-check">
              <input
                type="checkbox"
                :value="cv"
                x-model="filters.costs"
                @change="emitFiltersChanged()"
              />
              <span class="filter-cost-option-label" x-text="cv"></span>
            </label>
            <button
              type="button"
              class="filter-cost-only-btn"
              @click="setOnlyCost(cv)"
              :aria-label="'Show only cost ' + cv"
            >
              Only
            </button>
          </div>
        </template>
        <div class="filter-cost-panel-footer">
          <button
            type="button"
            class="filter-cost-foot-btn"
            @click="clearCostSelection()"
          >
            Clear
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="filter-group">
    <label for="type" class="filter-label">Type</label>
    <select
      x-model="filters.type"
      @change="emitFiltersChanged()"
      id="type"
      class="filter-select"
    >
      <option value="">Any Type</option>
      <option value="unit">Unit</option>
      <option value="colony">Colony</option>
      <option value="augment">Augment</option>
      <option value="reflex">Reflex</option>
    </select>
  </div>

  <div class="filter-group">
    <label for="secondaryType" class="filter-label">Secondary Type</label>
    <select
      x-model="filters.secondaryType"
      @change="emitFiltersChanged()"
      id="secondaryType"
      class="filter-select"
      :disabled="filters.type === 'reflex' || getAvailableSecondaryTypes().length === 0"
    >
      <option value="">Any Secondary</option>
      <template
        x-for="secondaryType in getAvailableSecondaryTypes()"
        :key="secondaryType"
      >
        <option
          :value="secondaryType"
          x-text="secondaryType.charAt(0).toUpperCase() + secondaryType.slice(1)"
        ></option>
      </template>
    </select>
  </div>

  <div class="filter-group" x-show="showFactionSelector">
    <label for="faction" class="filter-label">Faction</label>
    <select
      x-model="filters.faction"
      @change="emitFiltersChanged()"
      id="faction"
      class="filter-select"
    >
      <option value="">All Factions</option>
      <template x-for="faction in factions" :key="faction.slug">
        <option :value="faction.slug" x-text="faction.displayName"></option>
      </template>
    </select>
  </div>

  <div class="filter-group filter-group--actions">
    <span class="filter-label filter-label--spacer" aria-hidden="true"
      >&nbsp;</span
    >
    <button
      type="button"
      @click="clearFilters()"
      class="filter-btn filter-btn--clear"
      :disabled="!hasActiveFilters()"
    >
      Clear Filters
    </button>
  </div>
</div>

<script is:inline>
  function filterBarComponent(initialState) {
    var initialCosts = initialState.costs;
    var costsArr =
      Array.isArray(initialCosts) && initialCosts.length > 0
        ? initialCosts.map(String)
        : [];

    return {
      showFactionSelector: initialState.showFactionSelector ?? true,
      factions: initialState.factions ?? [],
      allCards: initialState.allCards ?? [],
      costDropdownOpen: false,
      filters: {
        search: initialState.search || "",
        costs: costsArr,
        type: initialState.type || "",
        secondaryType: initialState.secondaryType || "",
        faction: initialState.faction || "",
      },

      // Mapping of valid secondary types for each primary type (passed through initial state)
      validSecondaryTypesByType: initialState.validSecondaryTypesByType,

      init() {
        // Auto-clear costs that are no longer valid when type changes
        this.$watch('filters.type', () => this.clearInvalidCosts());
        this.$watch('filters.secondaryType', () => this.clearInvalidCosts());
      },

      clearInvalidCosts() {
        var available = this.getAvailableCosts();
        var invalid = this.filters.costs.filter(function(c) {
          return !available.includes(c);
        });
        if (invalid.length > 0) {
          this.filters.costs = this.filters.costs.filter(function(c) {
            return available.includes(c);
          });
          this.emitFiltersChanged();
        }
      },

      getAvailableCosts() {
        var cards = this.allCards;
        if (!cards || cards.length === 0) {
          return ["0", "1", "2", "3", "4", "5", "6", "7", "X"];
        }
        var currentType = this.filters.type;
        var currentSecondary = this.filters.secondaryType;
        var costsSet = {};
        for (var i = 0; i < cards.length; i++) {
          var card = cards[i];
          if (!card.cost) continue;
          if (currentType && card.type !== currentType) continue;
          if (currentSecondary) {
            var types = card.type_secondary || [];
            if (types.length > 0 && types.indexOf(currentSecondary) === -1) continue;
          }
          costsSet[card.cost] = true;
        }
        var costs = Object.keys(costsSet);
        costs.sort(function(a, b) {
          var oa = a === "X" ? 10 : parseInt(a, 10);
          var ob = b === "X" ? 10 : parseInt(b, 10);
          return oa - ob;
        });
        return costs.length > 0 ? costs : ["0", "1", "2", "3", "4", "5", "6", "7", "X"];
      },

      costTriggerLabel() {
        var c = this.filters.costs;
        if (!c || c.length === 0) return "All costs";
        var copy = c.slice();
        copy.sort(function (a, b) {
          var oa = a === "X" ? 10 : parseInt(a, 10);
          var ob = b === "X" ? 10 : parseInt(b, 10);
          return oa - ob;
        });
        return copy.join(", ");
      },

      hasActiveFilters() {
        var f = this.filters;
        return !!(
          f.search ||
          (f.costs && f.costs.length > 0) ||
          f.type ||
          f.secondaryType ||
          f.faction
        );
      },

      clearSearch() {
        this.filters.search = "";
        this.emitFiltersChanged();
      },

      clearCostSelection() {
        this.filters.costs = [];
        this.emitFiltersChanged();
      },

      setOnlyCost(cost) {
        this.filters.costs = [cost];
        this.emitFiltersChanged();
      },

      clearFilters() {
        this.filters = {
          search: "",
          costs: [],
          type: "",
          secondaryType: "",
          faction: "",
        };
        this.emitFiltersChanged();
      },

      // Get available secondary types based on current primary type
      getAvailableSecondaryTypes() {
        const currentType = this.filters.type;
        return (
          this.validSecondaryTypesByType[currentType] ||
          this.validSecondaryTypesByType[""]
        );
      },

      // Check if a secondary type is valid for the current primary type
      isSecondaryTypeValid(secondaryType) {
        if (!secondaryType) return true;
        const availableTypes = this.getAvailableSecondaryTypes();
        return availableTypes.includes(secondaryType);
      },

      emitFiltersChanged() {
        // Clear secondary type if it's not valid for the current primary type
        if (
          this.filters.type &&
          !this.isSecondaryTypeValid(this.filters.secondaryType)
        ) {
          this.filters.secondaryType = "";
        }

        var detail = {
          search: this.filters.search,
          costs: this.filters.costs.slice(),
          type: this.filters.type,
          secondaryType: this.filters.secondaryType,
          faction: this.filters.faction,
        };
        window.dispatchEvent(new CustomEvent("filters-changed", { detail }));
      },
    };
  }
</script>
