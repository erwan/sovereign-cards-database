<dialog
  class="card-lightbox"
  id="card-lightbox"
  aria-modal="true"
  aria-labelledby="card-lightbox-img"
>
  <div class="card-lightbox-panel">
    <form method="dialog" class="card-lightbox-close-wrap">
      <button type="submit" class="card-lightbox-close"> Close </button>
    </form>
    <img class="card-lightbox-img" id="card-lightbox-img" alt="" />
  </div>
</dialog>

<script is:inline>
  (function () {
    var dialog = document.getElementById("card-lightbox");
    var img = document.getElementById("card-lightbox-img");
    if (!dialog || !img) return;

    function openFrom(el) {
      var src = el.getAttribute("data-full-src");
      var name = el.getAttribute("data-card-name") || "";
      if (!src) return;
      img.src = src;
      img.alt = name;
      dialog.showModal();
    }

    document.addEventListener("click", function (e) {
      var item = e.target.closest(
        '.faction-detail[data-deck-view="list"] .card-item[data-full-src]'
      );
      if (!item) return;
      openFrom(item);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key !== "Enter" && e.key !== " ") return;
      var item = e.target.closest(
        '.faction-detail[data-deck-view="list"] .card-item[data-full-src]'
      );
      if (!item) return;
      e.preventDefault();
      openFrom(item);
    });

    dialog.addEventListener("click", function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>
