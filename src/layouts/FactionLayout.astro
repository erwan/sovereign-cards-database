---
import { getBaseUrl } from '../lib/baseUrl';
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const home = getBaseUrl();
---

<Layout title={title}>
  <main class="faction-main">
    <nav class="faction-nav">
      <a href={home}>← Home</a>
    </nav>
    <slot />
  </main>
</Layout>

<style>
  .faction-main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 1.25rem 2rem;
  }
  .faction-nav {
    margin-bottom: 1.25rem;
  }
  .faction-nav a {
    color: inherit;
  }
</style>
