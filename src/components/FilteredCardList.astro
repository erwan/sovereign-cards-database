---
import {
  cardBlockTypeLabel,
  compareCardsByCostThenName,
  type CardEntry,
} from "../lib/decks-content";

interface CardWithFactionInput extends CardEntry {
  factionSlug: string;
  factionName: string;
}

interface CardWithFaction extends CardWithFactionInput {
  typeLabel: string;
}

interface Props {
  cardData: CardWithFactionInput[];
  assetPrefix: string;
}

const { cardData: cards = [], assetPrefix } = Astro.props;

const sortedCards: CardWithFaction[] = [...cards]
  .sort(compareCardsByCostThenName)
  .map((card) => ({
    ...card,
    typeLabel: cardBlockTypeLabel(card),
  }));
---

<div
  class="filtered-card-list"
  x-data="filteredCardList(JSON.parse($el.dataset.config))"
  data-config={JSON.stringify({
    allCards: sortedCards,
    assetPrefix,
  })}
>
  <div class="result-count-row">
    <div class="result-count">
      <span x-text="filteredCards.length + ' of ' + allCards.length + ' cards'"
      ></span>
    </div>
    <div class="sort-group">
      <label for="sort-by" class="sort-label">Sort by</label>
      <select
        id="sort-by"
        class="sort-select"
        x-model="sortBy"
        @change="persistSort()"
      >
        <option value="cost">Cost</option>
        <option value="name">Name</option>
      </select>
    </div>
  </div>

  <!-- Cards List -->
  <ul class="card-list" x-html="renderCards()"></ul>

  <!-- No Results Message -->
  <div class="no-results" x-show="filteredCards.length === 0" x-cloak>
    <p>No cards match your current filters.</p>
  </div>
</div>

<script is:inline>
  window.filteredCardList = function filteredCardList({
    allCards,
    assetPrefix,
  }) {
    function escAttr(s) {
      return String(s == null ? "" : s)
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }
    function escText(s) {
      return String(s == null ? "" : s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }
    return {
      allCards,
      sortBy: "cost",
      filters: {
        search: "",
        costs: [],
        type: "",
        secondaryType: "",
        faction: "",
      },

      init() {
        try {
          var stored = localStorage.getItem("sovereign-cards-sort");
          if (stored === "name" || stored === "cost") this.sortBy = stored;
        } catch (e) {}
        var self = this;
        this._onFiltersChanged = function (event) {
          var d = event.detail || {};
          self.filters = {
            search: d.search || "",
            costs: Array.isArray(d.costs) ? d.costs.map(String) : [],
            type: d.type || "",
            secondaryType: d.secondaryType || "",
            faction: d.faction || "",
          };
        };
        window.addEventListener("filters-changed", this._onFiltersChanged);
      },

      persistSort() {
        try {
          localStorage.setItem("sovereign-cards-sort", this.sortBy);
        } catch (e) {}
      },

      compareCostThenName(a, b) {
        var ka = this.costSortKey(a.cost);
        var kb = this.costSortKey(b.cost);
        if (ka !== kb) return ka - kb;
        var byCostChar = String(a.cost).localeCompare(String(b.cost), undefined, {
          sensitivity: "base",
        });
        if (byCostChar !== 0) return byCostChar;
        return String(a.name).localeCompare(String(b.name), undefined, {
          sensitivity: "base",
        });
      },

      compareNameThenCost(a, b) {
        var byName = String(a.name).localeCompare(String(b.name), undefined, {
          sensitivity: "base",
        });
        if (byName !== 0) return byName;
        var ka = this.costSortKey(a.cost);
        var kb = this.costSortKey(b.cost);
        if (ka !== kb) return ka - kb;
        return String(a.cost).localeCompare(String(b.cost), undefined, {
          sensitivity: "base",
        });
      },

      get sortedFilteredCards() {
        var list = this.filteredCards.slice();
        var cmp =
          this.sortBy === "name"
            ? this.compareNameThenCost.bind(this)
            : this.compareCostThenName.bind(this);
        list.sort(cmp);
        return list;
      },

      get filteredCards() {
        return allCards.filter((card) => {
          // Search filter (case-insensitive, partial match on name)
          if (this.filters.search) {
            const searchLower = this.filters.search.toLowerCase();
            if (!card.name.toLowerCase().includes(searchLower)) {
              return false;
            }
          }

          if (this.filters.costs && this.filters.costs.length > 0) {
            var cardCost = String(card.cost);
            if (this.filters.costs.indexOf(cardCost) === -1) {
              return false;
            }
          }

          // Type filter
          if (this.filters.type && card.type !== this.filters.type) {
            return false;
          }

          // Secondary type filter
          if (this.filters.secondaryType) {
            const hasSecondaryType =
              card.type_secondary &&
              card.type_secondary.includes(this.filters.secondaryType);
            if (!hasSecondaryType) {
              return false;
            }
          }

          // Faction filter
          if (
            this.filters.faction &&
            card.factionSlug !== this.filters.faction
          ) {
            return false;
          }

          return true;
        });
      },

      costSortKey(cost) {
        if (cost.length === 1 && cost >= "0" && cost <= "8") {
          return cost.charCodeAt(0) - 48;
        }
        return 9; // X or other
      },

      renderCards() {
        if (this.filteredCards.length === 0) {
          return "";
        }

        return this.sortedFilteredCards
          .map((card) => {
            const cardSrc = `${assetPrefix}cards/${card.factionSlug}/${card.image}`;
            const reflex = card.type === "reflex" ? " card-cost--reflex" : "";
            return `
            <li>
              <div
                class="card-item"
                data-full-src="${escAttr(cardSrc)}"
                data-card-name="${escAttr(card.name)}"
                data-card-cost="${escAttr(String(card.cost))}"
              >
                <img
                  class="card-thumb"
                  src="${escAttr(cardSrc)}"
                  alt=""
                  width="120"
                  height="168"
                  loading="lazy"
                />
                <div class="card-meta">
                  <span class="card-name">${escText(card.name)}</span>
                   <span class="card-type">${escText(card.typeLabel ? card.type + " — " + card.typeLabel : card.type || "")}</span>
                  <span
                    class="card-cost${reflex}"
                    aria-hidden="true"
                  >
                    ${escText(String(card.cost))}
                  </span>
                </div>
              </div>
            </li>
          `;
          })
          .join("");
      },
    };
  };
</script>

<style>
  .filtered-card-list {
    width: 100%;
  }

  .result-count-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .result-count {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .sort-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sort-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sort-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: 0.375rem;
    background: var(--bg-base);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-family: inherit;
    min-width: 120px;
  }

  .sort-select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  [x-cloak] {
    display: none !important;
  }
</style>
