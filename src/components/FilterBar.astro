---
interface Faction {
  slug: string;
  displayName: string;
}

interface Props {
  searchPlaceholder?: string;
  showFactionSelector?: boolean;
  factions?: Faction[];
  validSecondaryTypesByType?: Record<string, string[]>;
  initialState?: {
    search?: string;
    costs?: string[];
    type?: string;
    secondaryType?: string;
    faction?: string;
  };
}

const {
  searchPlaceholder = "Search cards...",
  showFactionSelector = true,
  factions = [],
  validSecondaryTypesByType,
  initialState = {},
} = Astro.props;
---

<div
  class="filter-bar"
  x-data="filterBarComponent(JSON.parse($el.dataset.initialState))"
  data-initial-state={JSON.stringify({ ...initialState, showFactionSelector, factions, validSecondaryTypesByType })}
>
  <div class="filter-group filter-group--search">
    <label for="search" class="filter-label">Search</label>
    <div class="filter-search-wrap">
      <input
        type="text"
        id="search"
        x-model="filters.search"
        placeholder={searchPlaceholder}
        class="filter-input filter-input--search"
        @input.debounce.300ms="emitFiltersChanged()"
        autocomplete="off"
      />
      <button
        type="button"
        class="filter-search-clear"
        x-show="filters.search.length > 0"
        x-cloak
        @click="clearSearch()"
        aria-label="Clear search"
      >
        <span aria-hidden="true">×</span>
      </button>
    </div>
  </div>

  <div class="filter-group filter-group--cost">
    <span class="filter-label" id="filter-cost-heading">Cost</span>
    <div
      class="filter-cost-dropdown"
      @click.outside="costDropdownOpen = false"
      @keydown.escape.window="costDropdownOpen = false"
    >
      <button
        type="button"
        class="filter-cost-trigger"
        aria-haspopup="true"
        :aria-expanded="costDropdownOpen"
        :aria-label="'Filter by cost, current: ' + costTriggerLabel()"
        @click="costDropdownOpen = !costDropdownOpen"
      >
        <span class="filter-cost-trigger-text" x-text="costTriggerLabel()"></span>
        <span class="filter-cost-trigger-chevron" aria-hidden="true"></span>
      </button>
      <div
        class="filter-cost-panel"
        x-show="costDropdownOpen"
        x-cloak
        role="group"
        aria-label="Cost values"
      >
        <template x-for="cv in costValues" :key="cv">
          <label class="filter-cost-option">
            <input
              type="checkbox"
              :value="cv"
              x-model="filters.costs"
              @change="emitFiltersChanged()"
            />
            <span class="filter-cost-option-label" x-text="cv"></span>
          </label>
        </template>
        <div class="filter-cost-panel-footer">
          <button
            type="button"
            class="filter-cost-foot-btn"
            @click="clearCostSelection()"
          >
            Clear
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="filter-group">
    <label for="type" class="filter-label">Type</label>
    <select
      x-model="filters.type"
      @change="emitFiltersChanged()"
      id="type"
      class="filter-select"
    >
      <option value="">Any Type</option>
      <option value="unit">Unit</option>
      <option value="colony">Colony</option>
      <option value="augment">Augment</option>
      <option value="reflex">Reflex</option>
    </select>
  </div>

   <div class="filter-group">
    <label for="secondaryType" class="filter-label">Secondary Type</label>
    <select
      x-model="filters.secondaryType"
      @change="emitFiltersChanged()"
      id="secondaryType"
      class="filter-select"
      :disabled="filters.type === 'reflex' || getAvailableSecondaryTypes().length === 0"
    >
      <option value="">Any Secondary</option>
      <template x-for="secondaryType in getAvailableSecondaryTypes()" :key="secondaryType">
        <option :value="secondaryType" x-text="secondaryType.charAt(0).toUpperCase() + secondaryType.slice(1)"></option>
      </template>
    </select>
  </div>

  <div class="filter-group" x-show="showFactionSelector">
    <label for="faction" class="filter-label">Faction</label>
    <select
      x-model="filters.faction"
      @change="emitFiltersChanged()"
      id="faction"
      class="filter-select"
    >
      <option value="">All Factions</option>
      <template x-for="faction in factions" :key="faction.slug">
        <option :value="faction.slug" x-text="faction.displayName"></option>
      </template>
    </select>
  </div>

  <div class="filter-group filter-group--actions">
    <span class="filter-label filter-label--spacer" aria-hidden="true">&nbsp;</span>
    <button
      type="button"
      @click="clearFilters()"
      class="filter-btn filter-btn--clear"
      :disabled="!hasActiveFilters()"
    >
      Clear Filters
    </button>
  </div>
</div>

<script is:inline>
  function filterBarComponent(initialState) {
    var initialCosts = initialState.costs;
    var costsArr =
      Array.isArray(initialCosts) && initialCosts.length > 0
        ? initialCosts.map(String)
        : [];

    return {
      showFactionSelector: initialState.showFactionSelector ?? true,
      factions: initialState.factions ?? [],
      costDropdownOpen: false,
      costValues: ["0", "1", "2", "3", "4", "5", "6", "7", "X"],
      filters: {
        search: initialState.search || "",
        costs: costsArr,
        type: initialState.type || "",
        secondaryType: initialState.secondaryType || "",
        faction: initialState.faction || "",
      },

       // Mapping of valid secondary types for each primary type (passed through initial state)
      validSecondaryTypesByType: initialState.validSecondaryTypesByType,

      costTriggerLabel() {
        var c = this.filters.costs;
        if (!c || c.length === 0) return "All costs";
        var copy = c.slice();
        copy.sort(function (a, b) {
          var oa = a === "X" ? 10 : parseInt(a, 10);
          var ob = b === "X" ? 10 : parseInt(b, 10);
          return oa - ob;
        });
        return copy.join(", ");
      },

      hasActiveFilters() {
        var f = this.filters;
        return !!(
          f.search ||
          (f.costs && f.costs.length > 0) ||
          f.type ||
          f.secondaryType ||
          f.faction
        );
      },

      clearSearch() {
        this.filters.search = "";
        this.emitFiltersChanged();
      },

      clearCostSelection() {
        this.filters.costs = [];
        this.emitFiltersChanged();
      },

       clearFilters() {
        this.filters = {
          search: "",
          costs: [],
          type: "",
          secondaryType: "",
          faction: "",
        };
        this.emitFiltersChanged();
      },

      // Get available secondary types based on current primary type
      getAvailableSecondaryTypes() {
        const currentType = this.filters.type;
        return this.validSecondaryTypesByType[currentType] || this.validSecondaryTypesByType[''];
      },

      // Check if a secondary type is valid for the current primary type
      isSecondaryTypeValid(secondaryType) {
        if (!secondaryType) return true;
        const availableTypes = this.getAvailableSecondaryTypes();
        return availableTypes.includes(secondaryType);
      },

       emitFiltersChanged() {
        // Clear secondary type if it's not valid for the current primary type
        if (this.filters.type && !this.isSecondaryTypeValid(this.filters.secondaryType)) {
          this.filters.secondaryType = "";
        }

        var detail = {
          search: this.filters.search,
          costs: this.filters.costs.slice(),
          type: this.filters.type,
          secondaryType: this.filters.secondaryType,
          faction: this.filters.faction,
        };
        window.dispatchEvent(new CustomEvent("filters-changed", { detail }));
      },
    };
  }
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
    padding: 1.25rem 1.5rem;
    align-items: flex-end;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-soft);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .filter-group--search {
    flex: 1 1 14rem;
    min-width: min(100%, 12rem);
    max-width: 24rem;
  }

  .filter-group--cost {
    min-inline-size: 0;
    position: relative;
    z-index: 2;
  }

  .filter-cost-dropdown {
    position: relative;
    min-width: 10.5rem;
  }

  .filter-cost-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: 0.375rem;
    background: var(--bg-base);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .filter-cost-trigger:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border-strong));
  }

  .filter-cost-trigger:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .filter-cost-trigger-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .filter-cost-trigger-chevron {
    flex-shrink: 0;
    width: 0;
    height: 0;
    border-left: 0.28rem solid transparent;
    border-right: 0.28rem solid transparent;
    border-top: 0.38rem solid var(--text-muted);
    margin-top: 0.12rem;
    transition: transform 0.15s ease;
  }

  .filter-cost-trigger[aria-expanded="true"] .filter-cost-trigger-chevron {
    transform: rotate(180deg);
  }

  .filter-cost-panel {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 0.25rem);
    z-index: 40;
    padding: 0.5rem 0.65rem;
    max-height: min(18rem, 70vh);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 0.375rem;
    box-shadow:
      var(--shadow-soft),
      0 0.5rem 1.25rem rgba(0, 0, 0, 0.35);
  }

  .filter-cost-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--text-primary);
    padding: 0.2rem 0;
    border-radius: 0.25rem;
  }

  .filter-cost-option:hover {
    color: var(--accent-hover);
  }

  .filter-cost-option input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .filter-cost-option-label {
    font-variant-numeric: tabular-nums;
  }

  .filter-cost-panel-footer {
    margin-top: 0.35rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .filter-cost-foot-btn {
    padding: 0.25rem 0;
    border: none;
    background: none;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .filter-cost-foot-btn:hover {
    color: var(--accent-hover);
  }

  .filter-group--actions {
    flex-direction: column;
    margin-left: auto;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter-label--spacer {
    visibility: hidden;
    user-select: none;
    min-height: 1em;
  }

  .filter-search-wrap {
    position: relative;
    width: 100%;
  }

  .filter-input,
  .filter-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: 0.375rem;
    background: var(--bg-base);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-family: inherit;
    min-width: 120px;
  }

  .filter-input--search {
    min-width: 0;
    width: 100%;
    padding-right: 2.25rem;
  }

  .filter-search-clear {
    position: absolute;
    right: 0.3rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border: none;
    border-radius: 0.25rem;
    background: transparent;
    color: var(--text-muted);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .filter-search-clear:hover {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--text-muted) 14%, transparent);
  }

   .filter-input:focus,
   .filter-select:focus {
     outline: none;
     border-color: var(--accent);
     box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent);
   }

   .filter-select:disabled {
     opacity: 0.5;
     cursor: not-allowed;
     background: color-mix(in srgb, var(--border-subtle) 20%, var(--bg-base));
   }

  .filter-search-clear:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .cost-range {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cost-range-separator {
    color: var(--text-muted);
    font-weight: 600;
    flex-shrink: 0;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .filter-btn--clear {
    background: var(--bg-base);
    color: var(--text-primary);
    border: 1px solid var(--border-strong);
  }

  .filter-btn--clear:hover:not(:disabled) {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border-strong));
    background: color-mix(in srgb, var(--text-muted) 10%, var(--bg-base));
  }

  .filter-btn--clear:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  [x-cloak] {
    display: none !important;
  }

  @media (max-width: 768px) {
    .filter-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-group--search {
      max-width: none;
    }

    .filter-group--actions {
      margin-left: 0;
    }

    .filter-label--spacer {
      display: none;
    }

    .filter-input,
    .filter-select {
      min-width: 100%;
      width: 100%;
    }

    .filter-cost-dropdown {
      min-width: 100%;
    }
  }
</style>
