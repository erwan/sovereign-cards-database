---
import FactionLayout from '../../layouts/FactionLayout.astro';
import { getBaseUrl } from '../../lib/baseUrl';
import { loadDecks, type Deck } from '../../lib/decks';

export function getStaticPaths() {
  return loadDecks().map((deck) => ({
    params: { slug: deck.slug },
    props: { deck },
  }));
}

interface Props {
  deck: Deck;
}

const { deck } = Astro.props;
const base = getBaseUrl();
const assetPrefix = `${base}cards/${deck.slug}/`;
---

<FactionLayout title={`${deck.displayName} — Sovereign Cards`}>
  <h1>{deck.displayName}</h1>
  <ul class="card-list">
    {
      deck.cards.map((card) => (
        <li class="card-item">
          <img
            class="card-thumb"
            src={`${assetPrefix}${card.image}`}
            alt=""
            width="120"
            height="168"
            loading="lazy"
          />
          <div class="card-meta">
            <span class="card-name">{card.name}</span>
            <span class="card-type">{card.type}</span>
          </div>
        </li>
      ))
    }
  </ul>
</FactionLayout>

<style>
  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
  }
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
  }
  .card-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    border: 1px solid color-mix(in srgb, CanvasText 12%, transparent);
    border-radius: 0.5rem;
    padding: 0.75rem;
  }
  .card-thumb {
    display: block;
    width: 5rem;
    height: auto;
    object-fit: cover;
    border-radius: 0.25rem;
    flex-shrink: 0;
  }
  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .card-name {
    font-weight: 500;
  }
  .card-type {
    font-size: 0.875rem;
    opacity: 0.85;
    text-transform: capitalize;
  }
</style>
