---
import Layout from '../layouts/Layout.astro';
import { getBaseUrl } from '../lib/baseUrl';
import { loadDecks } from '../lib/decks';

const decks = loadDecks();
const base = getBaseUrl();
---

<Layout title="Sovereign Cards Database">
  <main class="home">
    <h1>Sovereign: Fall of Wormwood</h1>
    <p class="lede">
      Cards database by faction. Choose a deck to browse card names and types.
    </p>
    <ul class="deck-grid">
      {
        decks.map((deck) => (
          <li>
            <a class="deck-link" href={`${base}factions/${deck.slug}`}>
              <img
                class="deck-cover"
                src={`${base}cards/${deck.slug}/cover.png`}
                alt=""
                width="280"
                height="392"
                loading="lazy"
              />
              <span class="deck-name">{deck.displayName}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  .home {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 1.25rem 2rem;
  }
  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .lede {
    margin: 0 0 1.5rem;
    max-width: 40rem;
  }
  .deck-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
  }
  .deck-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: inherit;
    text-decoration: none;
  }
  .deck-link:hover .deck-name {
    text-decoration: underline;
  }
  .deck-cover {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.375rem;
    border: 1px solid color-mix(in srgb, CanvasText 12%, transparent);
  }
  .deck-name {
    font-weight: 500;
    text-align: center;
  }
</style>
